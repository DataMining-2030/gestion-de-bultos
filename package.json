{
  "name": "centro-de-control-de-despacho",
  "version": "1.1.1",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "install": "node install.js",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm start",
    "dev:frontend": "cd frontend && npm start",
    "build": "npm run build:frontend && npm run build:frontend:copy",
    "build:frontend": "npm --prefix frontend run build",
    "build:frontend:copy": "node scripts/copy-frontend-build.js",
    "build:backend:prod": "npm --prefix backend ci --omit=dev",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"electron . --disable-gpu\"",
    "pack": "npm run build && npm run build:backend:prod && electron-builder --dir",
    "dist": "npm run build && npm run build:backend:prod && electron-builder",
    "dist:win": "npm run dist -- --win --x64",
    "release": "node scripts/release.js",
    "dist:publish": "node scripts/publish.js"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.8.3",
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "cl.cmk.centro-control-despacho",
    "productName": "Centro de Control de Despacho",
    "directories": {
      "output": "dist"
    },
    "icon": "assets/icon.png",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "build/**",
      "backend/**",
      "package.json",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "backend/.env",
        "to": "backend/.env"
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      }
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "DataMining-2030",
      "repo": "gestion-de-bultos",
      "releaseType": "release"
    }
  }
}
